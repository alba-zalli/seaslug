slug_name = "Hedgpeth’s sapsucker"
scientific_name = "Elysia hedgpethi"
description = "I live along the Pacific coast, from southern British Columbia to northern Mexico. Shallow water and tide pools are best for me. I love to eat green algae, and I get extra energy by photosynthesizing using the algae’s chloroplasts!"
